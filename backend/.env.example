# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your local or MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/investment-agent

# AI Engine Configuration
# Get your free Groq API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Real-time Web Search (Tavily)
# Powers live news & financial data fetching. Get a free key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here


# For Gmail, use App Passwords in your Google Account security settings.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_google_app_password
